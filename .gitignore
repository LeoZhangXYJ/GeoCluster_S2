# ===== Large data files (not suitable for GitHub) =====

# Raw Sentinel-2 SAFE zip downloads (~2.2 GB)
data/raw_zip/*.zip

# Extracted SAFE products (~2.2 GB)
data/raw_safe/*.SAFE/

# Extracted JP2 bands (~500 MB)
data/raw_bands/*.jp2

# Preprocessed data: GeoTIFF stacks, masks, .npz (~136 MB)
# Generated by: python scripts/preprocess_s2.py
data/processed/*.tif
data/processed/*.png
data/processed/*.npz

# ===== Generated results (~367 MB) =====
# All output GeoTIFF, .npz, .png, .csv, .pt, .pdf files
# Generated by running the experiment scripts
results/**/*.tif
results/**/*.png
results/**/*.pdf
results/**/*.npz
results/**/*.csv
results/**/*.pt

# ===== Python =====
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/

# ===== OS / Editor =====
.DS_Store
Thumbs.db
.vscode/
